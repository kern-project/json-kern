//! Smoke tests for borrowed JSON parsing and compact rendering.

use base.test;
use base.mem.alloc.gpa;
use json;
use std.io;
use sys.mem.page;

fn check_scalars() void {
    let t = test.report(io.stderr())..&;
    let page = page()..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    " null "
        .parse_json()
        .should_ok()
        .sum(@loc(), t)
        .is_null()
        .should()
        .sum(@loc(), t);
    "true".parse_json()
        .should_ok()
        .sum(@loc(), t)
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    "false".parse_json()
        .should_ok()
        .sum(@loc(), t)
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);

    let number = "-12345"
        .parse_json()
        .should_ok()
        .sum(@loc(), t);
    number
        .number_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("-12345")
        .sum(@loc(), t);
    number
        .i64_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(i64.{-12345})
        .sum(@loc(), t);

    let string = "\"kern\\n\""
        .parse_json()
        .should_ok()
        .sum(@loc(), t);
    string
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("kern\\n")
        .sum(@loc(), t);

    string
        .string_decoded_len()
        .should_ok()
        .eq(5)
        .sum(@loc(), t);
    let mut decoded_buf = [16]u8.{undef};
    let decoded_len = string
        .write_string(decoded_buf..&[0 .. 16])
        .should_ok()
        .sum(@loc(), t);
    decoded_buf.&[0 .. decoded_len]
        .should()
        .eq("kern\n")
        .sum(@loc(), t);

    let emoji = "\"\\uD83D\\uDE80\""
        .parse_json()
        .should_ok()
        .sum(@loc(), t);
    let mut owned = emoji
        .clone_string(alloc)
        .should_ok()
        .sum(@loc(), t);
    defer owned..&.deinit(alloc);
    owned.&.as_str()
        .should()
        .eq([4]u8.{ 0xF0, 0x9F, 0x9A, 0x80 })
        .sum(@loc(), t);

    let mut short = [3]u8.{undef};
    emoji
        .write_string(short..&[0 .. 3])
        .should_err()
        .eq(json.StringError.ShortOutput)
        .sum(@loc(), t);

    "\"\\uD83D\""
        .parse_json()
        .should_ok()
        .sum(@loc(), t)
        .string_decoded_len()
        .should_err()
        .eq(json.StringError.{ InvalidUnicode: 0 })
        .sum(@loc(), t);
}

fn check_array_cursor() void {
    let t = test.report(io.stderr())..&;
    let value = "[1,true,{\"name\":\"kern\"}]"
        .parse_json()
        .should_ok()
        .sum(@loc(), t);
    let cursor = value.array().should_some().sum(@loc(), t)..&;

    let first = cursor
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    first
        .i64_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(i64.{1})
        .sum(@loc(), t);
    let second = cursor
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    second
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    let object = cursor
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    object.kind
        .should()
        .eq(json.Kind.Object)
        .sum(@loc(), t);
    cursor
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);
}

fn check_object_cursor_and_lookup() void {
    let t = test.report(io.stderr())..&;
    let page = page()..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();
    let value = "{\"name\":\"kern\",\"version\":7,\"name\":\"second\"}"
        .parse_json()
        .should_ok()
        .sum(@loc(), t);
    let cursor = value.object().should_some().sum(@loc(), t)..&;

    let entry = cursor
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    entry.key_text
        .should()
        .eq("name")
        .sum(@loc(), t);
    entry.value
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("kern")
        .sum(@loc(), t);

    let lookup = value.object().should_some().sum(@loc(), t)..&;
    let found = lookup
        .find("name")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    found
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("kern")
        .sum(@loc(), t);

    let escaped = "{\"na\\u006de\":\"decoded\",\"raw\":\"plain\"}"
        .parse_json()
        .should_ok()
        .sum(@loc(), t);
    let escaped_object = escaped.object().should_some().sum(@loc(), t)..&;
    let escaped_next = escaped_object
        .next()
        .should_ok()
        .sum(@loc(), t);
    let escaped_entry = escaped_next.should_some().sum(@loc(), t);
    escaped_entry
        .&.key_eq("name")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    let mut key = escaped_entry.&.clone_key(alloc)
        .should_ok()
        .sum(@loc(), t);
    defer key..&.deinit(alloc);
    key.&.as_str()
        .should()
        .eq("name")
        .sum(@loc(), t);

    let escaped_lookup = escaped.object().should_some().sum(@loc(), t)..&;
    escaped_lookup
        .find("name")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t)
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("decoded")
        .sum(@loc(), t);
}

fn check_parse_errors() void {
    let t = test.report(io.stderr())..&;

    ""
        .validate_json()
        .should_err()
        .eq(json.ParseError.EmptyInput)
        .sum(@loc(), t);
    "true false"
        .validate_json()
        .should_err()
        .eq(json.ParseError.{ TrailingData: 5 })
        .sum(@loc(), t);
    "[1 2]"
        .validate_json()
        .should_err()
        .eq(json.ParseError.{ MissingCommaOrEnd: 3 })
        .sum(@loc(), t);
    "{\"a\" 1}"
        .validate_json()
        .should_err()
        .eq(json.ParseError.{ MissingColon: 5 })
        .sum(@loc(), t);
    "\"\\x\""
        .validate_json()
        .should_err()
        .eq(json.ParseError.{ InvalidEscape: 2 })
        .sum(@loc(), t);
    "01"
        .validate_json()
        .should_err()
        .eq(json.ParseError.{ InvalidNumber: 1 })
        .sum(@loc(), t);
}

fn check_compact_render() void {
    let t = test.report(io.stderr())..&;
    let mut out = [64]u8.{undef};

    let written = "{ \"name\" : \"kern vm\", \"ok\" : true }"
        .render_json_compact(out..&[0 .. 64])
        .should_ok()
        .sum(@loc(), t);
    out.&[0 .. written]
        .should()
        .eq("{\"name\":\"kern vm\",\"ok\":true}")
        .sum(@loc(), t);

    let mut short = [4]u8.{0, 0, 0, 0};
    "[1,2,3]"
        .render_json_compact(short..&[0 .. 4])
        .should_err()
        .eq(json.RenderError.ShortOutput)
        .sum(@loc(), t);
}

fn check_owned_document() void {
    let t = test.report(io.stderr())..&;
    let page = page()..&;
    let alloc = gpa().on(page)..&;
    let doc0 = "{ \"name\" : \"kern\", \"enabled\" : true }"
        .parse_json_document(alloc)
        .should_ok()
        .sum(@loc(), t);
    let mut doc = doc0;
    defer doc..&.deinit(alloc);

    doc.&.as_json()
        .should()
        .eq("{\"name\":\"kern\",\"enabled\":true}")
        .sum(@loc(), t);

    let root = doc.&.root();
    let object = root.object().should_some().sum(@loc(), t)..&;
    let enabled = object
        .find("enabled")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    enabled
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);

    doc
        ..&.replace_root_json(alloc, "[1, 2, 3]")
        .should_ok()
        .sum(@loc(), t);
    doc.&.as_json()
        .should()
        .eq("[1,2,3]")
        .sum(@loc(), t);
}

fn main() i32 {
    check_scalars();
    check_array_cursor();
    check_object_cursor_and_lookup();
    check_parse_errors();
    check_compact_render();
    check_owned_document();
    return 0;
}
