//! Smoke tests for borrowed JSON parsing and compact rendering.

use base.test.{Report, report};
use base.io.Write;
use base.coll.string;
use base.mem.alloc.gpa;
use json;
use std.io;
use std.mem.Page;

// Covers scalar views, number conversion, and string decoding behavior.
fn check_scalars() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    " null "
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t)
        .is_null()
        .should()
        .sum(@loc(), t);
    "true".parse_json(alloc)
        .should_ok()
        .sum(@loc(), t)
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    "false".parse_json(alloc)
        .should_ok()
        .sum(@loc(), t)
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);

    let number = "-12345"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t);
    number
        .number_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("-12345")
        .sum(@loc(), t);
    number
        .i64_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq((0i64 - 12345i64))
        .sum(@loc(), t);
    number
        .f64_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(0.0 - 12345.0)
        .sum(@loc(), t);

    "1.25e3"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t)
        .f64_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(1250.0)
        .sum(@loc(), t);
    "1e309"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t)
        .require_f64()
        .should_err()
        .eq(json.NumberError.Overflow)
        .sum(@loc(), t);
    "true"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t)
        .require_f64()
        .should_err()
        .eq(json.NumberError.NotNumber)
        .sum(@loc(), t);
    json.Value.{ kind: .Number, raw: "01" }
        .require_f64()
        .should_err()
        .eq(json.NumberError.{ InvalidNumber: 1 })
        .sum(@loc(), t);
    json.Value.{ kind: .Number, raw: "true" }
        .require_f64()
        .should_err()
        .eq(json.NumberError.{ InvalidNumber: 0 })
        .sum(@loc(), t);

    let string = "\"kern\\n\""
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t);
    string
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("kern\\n")
        .sum(@loc(), t);

    string
        .string_decoded_len()
        .should_ok()
        .eq(5)
        .sum(@loc(), t);
    let mut decoded_buf: [16]u8 = undef;
    let decoded_len = string
        .write_string(decoded_buf..&[0...16])
        .should_ok()
        .sum(@loc(), t);
    decoded_buf.&[0...decoded_len]
        .should()
        .eq("kern\n")
        .sum(@loc(), t);

    let emoji = "\"\\uD83D\\uDE80\""
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t);
    let mut owned = emoji
        .clone_string(alloc)
        .should_ok()
        .sum(@loc(), t);
    defer owned..&.deinit(alloc);
    owned.&.as_str()
        .should()
        .eq([4]u8.{ 0xF0, 0x9F, 0x9A, 0x80 })
        .sum(@loc(), t);

    let mut short: [3]u8 = undef;
    emoji
        .write_string(short..&[0...3])
        .should_err()
        .eq(json.StringError.ShortOutput)
        .sum(@loc(), t);

    "\"\\uD83D\""
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t)
        .string_decoded_len()
        .should_err()
        .eq(json.StringError.{ InvalidUnicode: 0 })
        .sum(@loc(), t);
}

// Covers borrowed array cursor iteration without building an owned tree.
fn check_array_cursor() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    let value = "[1,true,{\"name\":\"kern\"}]"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t);
    let cursor = value.array().should_some().sum(@loc(), t)..&;

    let first = cursor
        .next(alloc)
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    first
        .i64_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(1i64)
        .sum(@loc(), t);
    let second = cursor
        .next(alloc)
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    second
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    let object = cursor
        .next(alloc)
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    object.kind
        .should()
        .eq(json.Kind.Object)
        .sum(@loc(), t);
    cursor
        .next(alloc)
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);
}

// Covers object cursor order, duplicate-key lookup, and decoded key matching.
fn check_object_cursor_and_lookup() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();
    let value = "{\"name\":\"kern\",\"version\":7,\"name\":\"second\"}"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t);
    let cursor = value.object().should_some().sum(@loc(), t)..&;

    let entry = cursor
        .next(alloc)
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    entry.key_text
        .should()
        .eq("name")
        .sum(@loc(), t);
    entry.value
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("kern")
        .sum(@loc(), t);

    let lookup = value.object().should_some().sum(@loc(), t)..&;
    let found = lookup
        .find(alloc, "name")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    found
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("kern")
        .sum(@loc(), t);

    let unique_lookup = value.object().should_some().sum(@loc(), t)..&;
    unique_lookup
        .find_unique(alloc, "version")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t)
        .i64_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(7i64)
        .sum(@loc(), t);
    let duplicate_lookup = value.object().should_some().sum(@loc(), t)..&;
    duplicate_lookup
        .find_unique(alloc, "name")
        .should_err()
        .eq(json.KeyError.DuplicateKey)
        .sum(@loc(), t);
    let duplicate_check = value.object().should_some().sum(@loc(), t)..&;
    duplicate_check
        .reject_duplicate_keys(alloc)
        .should_err()
        .eq(json.KeyError.DuplicateKey)
        .sum(@loc(), t);

    let escaped = "{\"na\\u006de\":\"decoded\",\"raw\":\"plain\"}"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t);
    let escaped_object = escaped.object().should_some().sum(@loc(), t)..&;
    let escaped_next = escaped_object
        .next(alloc)
        .should_ok()
        .sum(@loc(), t);
    let escaped_entry = escaped_next.should_some().sum(@loc(), t);
    escaped_entry
        .&.key_eq("name")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    let mut key = escaped_entry.&.clone_key(alloc)
        .should_ok()
        .sum(@loc(), t);
    defer key..&.deinit(alloc);
    key.&.as_str()
        .should()
        .eq("name")
        .sum(@loc(), t);

    let escaped_lookup = escaped.object().should_some().sum(@loc(), t)..&;
    escaped_lookup
        .find(alloc, "name")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t)
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq("decoded")
        .sum(@loc(), t);

    let escaped_duplicate = "{\"name\":1,\"na\\u006de\":2}"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t);
    let escaped_duplicate_check = escaped_duplicate.object().should_some().sum(@loc(), t)..&;
    escaped_duplicate_check
        .reject_duplicate_keys(alloc)
        .should_err()
        .eq(json.KeyError.DuplicateKey)
        .sum(@loc(), t);
}

// Covers representative parser diagnostics and deeply nested stack parsing.
fn check_parse_errors() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    ""
        .validate_json(alloc)
        .should_err()
        .eq(json.ParseError.EmptyInput)
        .sum(@loc(), t);
    "true false"
        .validate_json(alloc)
        .should_err()
        .eq(json.ParseError.{ TrailingData: 5 })
        .sum(@loc(), t);
    "[1 2]"
        .validate_json(alloc)
        .should_err()
        .eq(json.ParseError.{ MissingCommaOrEnd: 3 })
        .sum(@loc(), t);
    "[1,]"
        .validate_json(alloc)
        .should_err()
        .eq(json.ParseError.{ UnexpectedByte: 3 })
        .sum(@loc(), t);
    "{\"a\" 1}"
        .validate_json(alloc)
        .should_err()
        .eq(json.ParseError.{ MissingColon: 5 })
        .sum(@loc(), t);
    "{\"a\":1,}"
        .validate_json(alloc)
        .should_err()
        .eq(json.ParseError.{ UnexpectedByte: 7 })
        .sum(@loc(), t);
    "\"\\x\""
        .validate_json(alloc)
        .should_err()
        .eq(json.ParseError.{ InvalidEscape: 2 })
        .sum(@loc(), t);
    "01"
        .validate_json(alloc)
        .should_err()
        .eq(json.ParseError.{ InvalidNumber: 1 })
        .sum(@loc(), t);

    let err = "{\n  \"a\" 1\n}"
        .validate_json(alloc)
        .should_err()
        .sum(@loc(), t);
    err
        .should()
        .eq(json.ParseError.{ MissingColon: 8 })
        .sum(@loc(), t);
    let location = err
        .location_in("{\n  \"a\" 1\n}")
        .should_some()
        .sum(@loc(), t);
    location.line
        .should()
        .eq(2)
        .sum(@loc(), t);
    location.column
        .should()
        .eq(7)
        .sum(@loc(), t);

    let mut nested: [1025]u8 = undef;
    let mut i = 0;
    while (i < 512) {
        nested.[i] = b'[';
        i += 1;
    }
    nested.[512] = b'0';
    while (i > 0) {
        i -= 1;
        nested.[1024 - i] = b']';
    }
    nested..&[0...nested.len()]
        .validate_json(alloc)
        .should_ok()
        .sum(@loc(), t);
}

// Covers compact rendering into both fixed buffers and `base.io.Write`.
fn check_compact_render() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();
    let mut out: [64]u8 = undef;

    let written = "{ \"name\" : \"kern vm\", \"ok\" : true }"
        .render_json_compact(alloc, out..&[0...64])
        .should_ok()
        .sum(@loc(), t);
    out.&[0...written]
        .should()
        .eq("{\"name\":\"kern vm\",\"ok\":true}")
        .sum(@loc(), t);

    let mut short = [4]u8.{0, 0, 0, 0};
    "[1,2,3]"
        .render_json_compact(alloc, short..&[0...4])
        .should_err()
        .eq(json.RenderError.ShortOutput)
        .sum(@loc(), t);

    let mut sink = string();
    defer sink..&.deinit(alloc);
    let mut string_writer = sink..&.writer(alloc);
    let writer = (string_writer..& as &mut Write);
    let writer_count = "{ \"items\" : [ 1, 2 ] }"
        .write_json_compact(alloc, writer)
        .should_ok()
        .sum(@loc(), t);
    writer_count
        .should()
        .eq(15)
        .sum(@loc(), t);
    sink.&.as_str()
        .should()
        .eq("{\"items\":[1,2]}")
        .sum(@loc(), t);
}

// Covers owned compact document creation, root views, and whole-root replace.
fn check_owned_document() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    let doc0 = "{ \"name\" : \"kern\", \"enabled\" : true }"
        .parse_json_document(alloc)
        .should_ok()
        .sum(@loc(), t);
    let mut doc = doc0;
    defer doc..&.deinit(alloc);

    doc.&.as_json()
        .should()
        .eq("{\"name\":\"kern\",\"enabled\":true}")
        .sum(@loc(), t);

    let root = doc.&.root(alloc);
    let object = root.object().should_some().sum(@loc(), t)..&;
    let enabled = object
        .find(alloc, "enabled")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    enabled
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);

    doc
        ..&.replace_root_json(alloc, "[1, 2, 3]")
        .should_ok()
        .sum(@loc(), t);
    doc.&.as_json()
        .should()
        .eq("[1,2,3]")
        .sum(@loc(), t);
}

// Runs the smoke suite as a Craft test target.
#[test]
fn smoke() i32 {
    check_scalars();
    check_array_cursor();
    check_object_cursor_and_lookup();
    check_parse_errors();
    check_compact_render();
    check_owned_document();
    return 0;
}
