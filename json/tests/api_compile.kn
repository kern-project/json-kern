//! Compile-time coverage for README-shaped json flows.

use json;
use base.coll.string;
use base.io.Write;
use base.mem.alloc.gpa;
use std.mem.Page;

enum AppError {
    Parse: json.ParseError,
    Key: json.KeyError,
    Render: json.RenderError,
}

// Keeps the README-shaped fluent API path compiling as a real program.
fn app() void!AppError {
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    let .{ Ok: value } = "{\"name\":\"kern\",\"enabled\":true}".parse_json(alloc) else {
        .{ Err: err } => return .{ Err: .{ Parse: err } },
    };

    let .{ Some: object0 } = value.object() else {
        return .{ Err: .{ Parse: .EmptyInput } };
    };
    let mut object = object0;
    let lookup = object..&;
    let .{ Ok: enabled } = lookup.find(alloc, "enabled") else {
        .{ Err: err } => return .{ Err: .{ Key: err } },
    };
    let .{ Some: flag } = enabled else return .{ Err: .{ Parse: .EmptyInput } };
    let .{ Some: enabled_flag } = flag.bool_value() else {
        return .{ Err: .{ Parse: .EmptyInput } };
    };
    if (!enabled_flag) {
        return .{ Err: .{ Parse: .EmptyInput } };
    }

    let mut out: [32]u8 = undef;
    _ = value.render_compact(alloc, out..&[0...32])
        .map_err([](err: json.RenderError) AppError { return .{ Render: err }; })
        .?;

    let mut compact = string();
    defer compact..&.deinit(alloc);
    let mut string_writer = compact..&.writer(alloc);
    let writer = (string_writer..& as &mut Write);
    _ = value.write_compact(alloc, writer)
        .map_err([](err: json.RenderError) AppError { return .{ Render: err }; })
        .?;

    let doc0 = value.clone_document(alloc)
        .map_err([](_: json.DocumentError) AppError {
            return .{ Render: .{ Parse: .EmptyInput } };
        })
        .?;
    let mut doc = doc0;
    defer doc..&.deinit(alloc);
    _ = doc.&.root(alloc);
    return .{ Ok: {} };
}

// Compile-only API coverage test.
#[test]
fn api_compile() i32 {
    let .{ Ok: _ } = app() else return 1;
    return 0;
}
