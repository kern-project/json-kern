//! Extended conformance checks for `json-kern`.
//!
//! The cases are shaped after RFC 8259 and the public JSONTestSuite naming
//! convention: `y_` inputs must parse, `n_` inputs must reject, and `i_`
//! inputs document implementation-defined pressure cases that should not crash.

use base.test.{Report, report};
use base.cmp.{Ordering, LESS, EQUAL, GREATER};
use base.io.Write;
use base.coll.{List, String, string};
use base.mem.alloc.gpa;
use json;
use std.fs;
use std.io;
use std.mem.Page;

struct Case {
    name: &[u8],
    text: &[u8],
};

struct SuiteStats {
    accepted: usize = 0,
    rejected: usize = 0,
    implementation: usize = 0,
};

const VALID_CASES = [_]Case.{
    .{ name: "y_literal_null", text: "null" },
    .{ name: "y_literal_true", text: "true" },
    .{ name: "y_literal_false", text: "false" },
    .{ name: "y_string_empty", text: "\"\"" },
    .{ name: "y_string_escapes", text: "\"\\\\\\/\\b\\f\\n\\r\\t\"" },
    .{ name: "y_string_unicode_bmp", text: "\"\\u2603\"" },
    .{ name: "y_string_unicode_pair", text: "\"\\uD834\\uDD1E\"" },
    .{ name: "y_number_zero", text: "0" },
    .{ name: "y_number_negative_zero", text: "-0" },
    .{ name: "y_number_frac", text: "123.456" },
    .{ name: "y_number_exp", text: "1.2e-3" },
    .{ name: "y_array_empty", text: "[]" },
    .{ name: "y_array_nested", text: "[[],[1,2,3],{\"a\":true}]" },
    .{ name: "y_object_empty", text: "{}" },
    .{ name: "y_object_nested", text: "{\"a\":{\"b\":[null,false,true]},\"c\":\"d\"}" },
    .{ name: "y_whitespace", text: " \n\r\t { \"a\" : [ 1 , 2 ] } \t" },
};

const INVALID_CASES = [_]Case.{
    .{ name: "n_empty", text: "" },
    .{ name: "n_literal_partial", text: "tru" },
    .{ name: "n_literal_trailing", text: "true false" },
    .{ name: "n_number_leading_zero", text: "01" },
    .{ name: "n_number_missing_int", text: "-.1" },
    .{ name: "n_number_missing_frac_digit", text: "1." },
    .{ name: "n_number_missing_exp_digit", text: "1e" },
    .{ name: "n_string_bad_escape", text: "\"\\x\"" },
    .{ name: "n_string_bad_unicode_hex", text: "\"\\u12X4\"" },
    .{ name: "n_string_control_char", text: "\"\n\"" },
    .{ name: "n_string_unterminated", text: "\"abc" },
    .{ name: "n_array_trailing_comma", text: "[1,]" },
    .{ name: "n_array_missing_comma", text: "[1 2]" },
    .{ name: "n_object_unquoted_key", text: "{a:1}" },
    .{ name: "n_object_missing_colon", text: "{\"a\" 1}" },
    .{ name: "n_object_trailing_comma", text: "{\"a\":1,}" },
};

const IMPLEMENTATION_CASES = [_]Case.{
    .{ name: "i_deep_small", text: "[[[[[0]]]]]" },
    .{ name: "i_large_integer_text", text: "123456789012345678901234567890" },
};

// Sorts fixture entries so JSONTestSuite results are deterministic.
fn case_name_cmp(lhs: fs.OwnedDirEntry, rhs: fs.OwnedDirEntry) Ordering {
    return lhs.name.lex_cmp(rhs.name);
}

// Keeps path allocation and error shape local to the conformance runner.
fn join_path(
    alloc: &mut base.mem.alloc.Allocator,
    base: &[u8],
    child: &[u8],
) String!fs.Error {
    return fs.join(alloc, base, child);
}

// Runs the mirrored JSONTestSuite `test_parsing` corpus.
fn check_json_test_suite() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    let mut suite_dir = join_path(alloc, JSON_TEST_SUITE_ROOT, "test_parsing")
        .should_ok()
        .sum(@loc(), t);
    defer suite_dir..&.deinit(alloc);

    let suite_dir_path = suite_dir.&.path();
    let mut entries = suite_dir_path.read_dir_entries(alloc)
        .should_ok()
        .sum(@loc(), t);
    defer entries..&.deinit(alloc);
    entries..&.as_mut_slice().sort_by(case_name_cmp);

    let mut stats = SuiteStats.{};
    for entry in entries.&.as_slice().iter() {
        if (!entry.is_file()) {
            continue;
        }

        let name = entry.name;
        if (!name.ends_with(".json")) {
            continue;
        }
        let mut case_path = join_path(alloc, suite_dir.&.as_str(), name)
            .should_ok()
            .sum(@loc(), t);
        defer case_path..&.deinit(alloc);

        let mut bytes = case_path.&.path().read_all(alloc)
            .should_ok()
            .sum(@loc(), t);
        defer bytes..&.deinit(alloc);
        let result = bytes.&.as_slice().validate_json(alloc);

        if (name.starts_with("y_")) {
            result.should_ok().sum(@loc(), t);
            stats.accepted += 1;
        } else if (name.starts_with("n_")) {
            _ = result.should_err().sum(@loc(), t);
            stats.rejected += 1;
        } else if (name.starts_with("i_")) {
            _ = result;
            stats.implementation += 1;
        }
    }

    stats.accepted
        .should()
        .eq(95)
        .sum(@loc(), t);
    stats.rejected
        .should()
        .eq(188)
        .sum(@loc(), t);
    stats.implementation
        .should()
        .eq(35)
        .sum(@loc(), t);
    "JSONTestSuite test_parsing: accepted={} rejected={} implementation={}".fmt(
        .{stats.accepted, stats.rejected, stats.implementation}
    ).println();
}

// Ensures valid built-in cases parse, validate, and compact back to JSON.
fn check_valid_cases() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    for case in VALID_CASES.iter() {
        case.text
            .validate_json(alloc)
            .should_ok()
            .sum(@loc(), t);
        let value = case.text
            .parse_json(alloc)
            .should_ok()
            .sum(@loc(), t);
        let mut compact: [256]u8 = undef;
        let written = value
            .render_compact(alloc, compact..&[0...compact.@len()])
            .should_ok()
            .sum(@loc(), t);
        compact.&[0...written]
            .validate_json(alloc)
            .should_ok()
            .sum(@loc(), t);
        _ = case.name;
    }
}

// Ensures invalid built-in cases fail validation.
fn check_invalid_cases() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    for case in INVALID_CASES.iter() {
        _ = case.text
            .validate_json(alloc)
            .should_err()
            .sum(@loc(), t);
        _ = case.name;
    }
}

// Ensures implementation-pressure cases are accepted without crashing.
fn check_implementation_cases() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    for case in IMPLEMENTATION_CASES.iter() {
        case.text
            .validate_json(alloc)
            .should_ok()
            .sum(@loc(), t);
        _ = case.name;
    }
}

// Covers escape decoding and decoded object-key lookup behavior.
fn check_strings_and_lookup() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    let value = "{\"plain\":\"abc\",\"escaped\":\"a\\u002Fb\",\"music\":\"\\uD834\\uDD1E\"}"
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t);
    let object = value.object().should_some().sum(@loc(), t)..&;

    let escaped = object
        .find(alloc, "escaped")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    let mut decoded = escaped
        .clone_string(alloc)
        .should_ok()
        .sum(@loc(), t);
    defer decoded..&.deinit(alloc);
    decoded.&.as_str()
        .should()
        .eq("a/b")
        .sum(@loc(), t);

    "\"\\uDEAD\""
        .parse_json(alloc)
        .should_ok()
        .sum(@loc(), t)
        .string_decoded_len()
        .should_err()
        .eq(json.StringError.{ InvalidUnicode: 0 })
        .sum(@loc(), t);
}

// Covers owned document compaction and replacement round trips.
fn check_document_roundtrip() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    let mut doc = "{ \"items\" : [ { \"id\" : 1 }, { \"id\" : 2 } ] }"
        .parse_json_document(alloc)
        .should_ok()
        .sum(@loc(), t);
    defer doc..&.deinit(alloc);

    doc.&.as_json()
        .should()
        .eq("{\"items\":[{\"id\":1},{\"id\":2}]}")
        .sum(@loc(), t);
    doc
        ..&.replace_root_json(alloc, "{\"ok\":true}")
        .should_ok()
        .sum(@loc(), t);
    doc.&.root(alloc)
        .object()
        .should_some()
        .sum(@loc(), t)
        ..&.find(alloc, "ok")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t)
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
}

// Covers compact streaming through `base.io.Write`.
fn check_writer() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let alloc = gpa().on(page)..&;
    defer alloc.deinit();

    let mut out = string();
    defer out..&.deinit(alloc);
    let mut string_writer = out..&.writer(alloc);
    let writer = (string_writer..& as &mut Write);
    let count = "[ true, false, null, { \"a\" : \"b\" } ]"
        .write_json_compact(alloc, writer)
        .should_ok()
        .sum(@loc(), t);
    count
        .should()
        .eq(27)
        .sum(@loc(), t);
    out.&.as_str()
        .should()
        .eq("[true,false,null,{\"a\":\"b\"}]")
        .sum(@loc(), t);
}

// Runs the extended conformance suite.
fn main() i32 {
    check_valid_cases();
    check_invalid_cases();
    check_implementation_cases();
    check_json_test_suite();
    check_strings_and_lookup();
    check_document_roundtrip();
    check_writer();
    return 0;
}
